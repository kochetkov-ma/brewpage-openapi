{
  "name": "brewpage-mcp",
  "version": "1.1.0",
  "description": "MCP server for BrewPage — publish and manage HTML, KV, JSON, and file content from AI assistants",
  "type": "module",
  "bin": {
    "brewpage-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "brewpage",
    "claude",
    "claude-desktop",
    "claude-code",
    "ai",
    "hosting",
    "html",
    "markdown",
    "api"
  ],
  "author": {
    "name": "Maksim Kochetkov",
    "url": "https://github.com/kochetkov-ma"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kochetkov-ma/brewpage-openapi.git",
    "directory": "mcp-server"
  },
  "homepage": "https://brewpage.app",
  "bugs": {
    "url": "https://github.com/kochetkov-ma/brewpage-openapi/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
