---
interface Props {
  steps: { title: string; description: string }[];
}
const { steps } = Astro.props;
---

<div class="not-prose my-8">
  <ol class="tl">
    {steps.map((step) => (
      <li>
        <strong>{step.title}</strong>
        <p>{step.description}</p>
      </li>
    ))}
  </ol>
</div>

<style>
  .tl {
    list-style: none;
    padding: 0;
    margin: 0;
    counter-reset: step-counter;
  }

  .tl :global(li) {
    display: grid;
    grid-template-columns: 2.5rem 1fr;
    gap: 0 1rem;
    position: relative;
    padding-bottom: 1.75rem;
    counter-increment: step-counter;
  }

  .tl :global(li:last-child) {
    padding-bottom: 0;
  }

  /* Numbered circle */
  .tl :global(li)::before {
    content: counter(step-counter);
    grid-column: 1;
    grid-row: 1 / -1;
    align-self: start;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 9999px;
    background: oklch(var(--p));
    color: oklch(var(--pc));
    font-weight: 800;
    font-size: 0.95rem;
    z-index: 1;
  }

  /* Connecting line */
  .tl :global(li)::after {
    content: '';
    position: absolute;
    left: 1.125rem;
    top: 2.5rem;
    bottom: 0;
    width: 0.25rem;
    border-radius: 0.125rem;
    background: oklch(var(--p));
  }

  .tl :global(li:last-child)::after {
    display: none;
  }

  /* Title */
  .tl :global(strong) {
    grid-column: 2;
    font-size: 1.05rem;
    font-weight: 700;
    color: #E7E5E4;
    line-height: 2.5rem;
  }

  /* Description */
  .tl :global(p) {
    grid-column: 2;
    font-size: 0.875rem;
    color: #a8a29e;
    margin: 0.125rem 0 0 0;
    line-height: 1.6;
  }
</style>
