---
import { GITHUB_URL } from '../../utils/github';
---

<footer class="border-t border-base-300 py-8" role="contentinfo">
  <div class="max-w-5xl mx-auto px-4 lg:px-8 text-sm text-base-content/60">
    <div class="flex flex-col sm:flex-row justify-between gap-4">
      <div>
        <p>BrewPage &mdash; HTML/KV/JSON/file hosting</p>
        <p class="mt-1">MIT License</p>
      </div>
      <nav class="flex items-center gap-4" aria-label="Footer links">
        <a href="https://brewpage.app" target="_blank" rel="noopener noreferrer" class="hover:text-primary transition-colors">brewpage.app</a>
        <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer" class="hover:text-primary transition-colors">GitHub</a>
      </nav>
    </div>
  </div>
</footer>
