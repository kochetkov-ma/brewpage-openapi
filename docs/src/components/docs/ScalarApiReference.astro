---
---

<div id="scalar-container" class="not-prose mt-8">
  <div id="scalar-loading" class="flex items-center justify-center py-20 text-base-content/50">
    <span class="loading loading-spinner loading-lg text-primary mr-3"></span>
    Loading API Reference...
  </div>
  <div id="scalar-api"></div>
</div>

<style>
  #scalar-api :global(.scalar-app) {
    --scalar-color-1: #EBBB40;
    --scalar-color-accent: #EBBB40;
  }
</style>

<script>
  const container = document.getElementById('scalar-api');
  const loading = document.getElementById('scalar-loading');
  if (container && !container.dataset.initialized) {
    container.dataset.initialized = 'true';

    const script = document.createElement('script');
    script.src = 'https://cdn.jsdelivr.net/npm/@scalar/api-reference@1.25.106/dist/browser/standalone.min.js';
    script.onload = () => {
      if (loading) loading.style.display = 'none';
      const el = document.createElement('api-reference');
      el.setAttribute('data-url', '/brewpage-openapi/openapi.json');
      el.setAttribute('data-configuration', JSON.stringify({
        theme: 'kepler',
        layout: 'modern',
        darkMode: true,
        hideModels: false,
        hideDownloadButton: false,
        hiddenClients: [],
        defaultHttpClient: { targetKey: 'shell', clientKey: 'curl' },
        metaData: {
          title: 'BrewPage API Reference',
          description: 'Interactive API documentation for BrewPage',
        },
      }));
      container.appendChild(el);
    };
    document.head.appendChild(script);
  }
</script>
