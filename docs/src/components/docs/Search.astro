<dialog id="search-dialog" class="modal" aria-label="Search documentation">
  <div class="modal-box bg-base-200 w-11/12 max-w-2xl">
    <div id="pagefind-search"></div>
  </div>
  <form method="dialog" class="modal-backdrop">
    <button>close</button>
  </form>
</dialog>

<script>
  const dialog = document.getElementById('search-dialog') as HTMLDialogElement | null;
  const container = document.getElementById('pagefind-search');

  if (dialog && container && !container.dataset.initialized) {
    container.dataset.initialized = 'true';

    import('@pagefind/default-ui').then(({ PagefindUI }) => {
      new PagefindUI({
        element: '#pagefind-search',
        bundlePath: '/brewpage-openapi/pagefind/',
        showSubResults: true,
        showImages: false,
        autofocus: true,
      });
    });

    document.addEventListener('keydown', (e: KeyboardEvent) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        if (dialog.open) {
          dialog.close();
        } else {
          dialog.showModal();
        }
      }
    });

    const searchBtn = document.getElementById('search-btn');
    if (searchBtn) {
      searchBtn.addEventListener('click', () => {
        dialog.showModal();
      });
    }

    const searchBtnMobile = document.getElementById('search-btn-mobile');
    if (searchBtnMobile) {
      searchBtnMobile.addEventListener('click', () => {
        dialog.showModal();
      });
    }
  }
</script>
